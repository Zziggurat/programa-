{
  "name": "tablero-studio",
  "version": "0.1.0",
  "description": "Núcleo de TableroStudio: diseño de tableros eléctricos con DRC, numeración IEC, bornes, ruteo de cables y documentación automática",
  "type": "module",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/*.test.js",
    "ejemplo": "tsc && node dist/ejemplo/generar.js",
    "editor": "vite app",
    "editor:build": "vite build app",
    "empaquetar": "vite build app && node app/empaquetar.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/three": "^0.170.0",
    "playwright-core": "^1.61.1",
    "three": "^0.170.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.2"
  }
}
